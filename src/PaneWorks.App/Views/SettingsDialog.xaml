<Window x:Class="PaneWorks.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PaneWorks 设置"
        Width="500"
        MinWidth="500"
        MaxWidth="500"
        MinHeight="430"
        MaxHeight="680"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        TextElement.Foreground="{StaticResource PaneTextBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="RoundedCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PaneTextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBoxFrame"
                                    Width="22"
                                    Height="22"
                                    VerticalAlignment="Center"
                                    Background="#18FFFFFF"
                                    BorderBrush="#54FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="7">
                                <Path x:Name="CheckMark"
                                      Width="12"
                                      Height="9"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M1,4.5 L4.2,8 L11,1"
                                      Stroke="#0F172A"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeThickness="2.2"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Margin="10,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxFrame" Property="BorderBrush" Value="#8A58AFFF" />
                                <Setter TargetName="CheckBoxFrame" Property="Background" Value="#222F80ED" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxFrame" Property="Background" Value="#FF63F5" />
                                <Setter TargetName="CheckBoxFrame" Property="BorderBrush" Value="#FFFF9BF9" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckBoxFrame" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="20"
            Background="#EE101219"
            BorderBrush="#28FFFFFF"
            BorderThickness="1"
            CornerRadius="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="-20,-20,-20,0"
                    Padding="20,16,20,14"
                    Background="#FA0B0E16"
                    CornerRadius="30,30,0,0"
                    MouseLeftButtonDown="HeaderDragArea_MouseLeftButtonDown">
                <Grid Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="23"
                                       FontWeight="Bold"
                                       Foreground="#F7F8FF"
                                       Text="设置" />
                            <Border Margin="12,5,0,0"
                                    Padding="8,3"
                                    VerticalAlignment="Top"
                                    Background="#1C2F80ED"
                                    BorderBrush="#4D58AFFF"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#58AFFF"
                                           Text="快捷键与启动" />
                            </Border>
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#CDD3DF"
                                   Text="自定义用户分区吸附键、临时调整区吸附键、收进托盘快捷键，以及开机启动行为。点击“开始录制”后直接按下你想要的快捷键组合。"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="38"
                            Height="38"
                            MinWidth="38"
                            MinHeight="38"
                            Margin="16,-4,0,0"
                            Style="{StaticResource CircleIconButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="关闭">
                        <Viewbox Width="15"
                                 Height="15"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path Data="M2,2 L14,14 M14,2 L2,14"
                                  Stroke="{StaticResource PaneTextBrush}"
                                  StrokeEndLineCap="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeThickness="2.4" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2"
                          MaxHeight="470"
                          VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Margin="0,0,0,8"
                                   FontSize="13"
                                   Foreground="#58AFFF"
                                   Text="用户分区吸附键" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="116" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SnapModifierTextBox"
                                     Margin="0,0,14,0"
                                     IsReadOnly="True"
                                     FontSize="14"
                                     Text="Shift" />
                            <Button Grid.Column="1"
                                    x:Name="RecordSnapShortcutButton"
                                    Click="RecordSnapShortcutButton_Click"
                                    Content="开始录制" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Margin="0,0,0,8"
                                   FontSize="13"
                                   Foreground="#58AFFF"
                                   Text="临时调整区吸附键" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="116" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="RuntimeSessionShortcutTextBox"
                                     Margin="0,0,14,0"
                                     IsReadOnly="True"
                                     FontSize="14"
                                     Text="Ctrl + Shift" />
                            <Button Grid.Column="1"
                                    x:Name="RecordRuntimeSessionShortcutButton"
                                    Click="RecordRuntimeSessionShortcutButton_Click"
                                    Content="开始录制" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="4">
                        <TextBlock Margin="0,0,0,8"
                                   FontSize="13"
                                   Foreground="#58AFFF"
                                   Text="收进托盘快捷键" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="116" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="MinimizeShortcutTextBox"
                                     Margin="0,0,14,0"
                                     IsReadOnly="True"
                                     FontSize="14"
                                     Text="Esc" />
                            <Button Grid.Column="1"
                                    x:Name="RecordMinimizeShortcutButton"
                                    Click="RecordMinimizeShortcutButton_Click"
                                    Content="开始录制" />
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="6"
                            Padding="14"
                            Margin="0,10,0,0"
                            Background="#66101219"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="22">
                        <StackPanel>
                            <CheckBox x:Name="LaunchAtStartupCheckBox"
                                      Style="{StaticResource RoundedCheckBoxStyle}"
                                      Content="开机自动启动 PaneWorks" />
                            <TextBlock x:Name="RecordingHintTextBlock"
                                       Margin="0,14,0,0"
                                       Foreground="#CDD3DF"
                                       Text="说明：用户分区吸附键默认是 Shift；临时调整区吸附键默认是 Ctrl + Shift。两个快捷键都支持完全自定义。"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="10"
                            Padding="14"
                            Margin="0,6,0,0"
                            Background="#401B2230"
                            BorderBrush="#2258AFFF"
                            BorderThickness="1"
                            CornerRadius="22">
                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#F7F8FF"
                                       Text="诊断与文件" />
                            <TextBlock Margin="0,6,0,12"
                                       Foreground="#AEB8C8"
                                       Text="遇到吸附或工作区恢复问题时，可直接打开本地目录，或复制诊断信息用于反馈。"
                                       TextWrapping="Wrap" />
                            <UniformGrid Columns="2">
                                <Button Margin="0,0,8,0"
                                        Click="OpenConfigDirectoryButton_Click"
                                        Content="配置目录" />
                                <Button Margin="8,0,0,0"
                                        Click="OpenLayoutsDirectoryButton_Click"
                                        Content="布局目录" />
                                <Button Margin="0,8,8,0"
                                        Click="OpenLogsDirectoryButton_Click"
                                        Content="日志目录" />
                                <Button Margin="8,8,0,0"
                                        Click="OpenLastWorkspaceRestoreReportButton_Click"
                                        Content="恢复报告" />
                                <Button Margin="0,8,8,0"
                                        Click="CopyDiagnosticsButton_Click"
                                        Content="复制诊断信息" />
                                <Button Margin="8,8,0,0"
                                        Click="ClearDiagnosticsButton_Click"
                                        Content="清理诊断文件" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="8"
                          Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Width="144"
                                HorizontalAlignment="Left"
                                Click="RestoreDefaultsButton_Click"
                                Content="恢复默认快捷键" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Width="118"
                                    Margin="0,0,14,0"
                                    IsCancel="True"
                                    Content="取消" />
                            <Button Width="118"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsDefault="True"
                                    Click="ConfirmButton_Click"
                                    Content="保存设置" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
