<Window x:Class="PaneWorks.App.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 PaneWorks"
        Width="420"
        MinWidth="420"
        MaxWidth="420"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        TextElement.Foreground="{StaticResource PaneTextBrush}">
    <Window.Resources>
        <Geometry x:Key="RefreshIconGeometry">M12,4V1L8,5L12,9V6C15.31,6 18,8.69 18,12C18,13.01 17.75,13.96 17.3,14.8L18.76,16.26C19.54,15.04 20,13.58 20,12C20,7.58 16.42,4 12,4ZM5.24,7.74C4.46,8.96 4,10.42 4,12C4,16.42 7.58,20 12,20V23L16,19L12,15V18C8.69,18 6,15.31 6,12C6,10.99 6.25,10.04 6.7,9.2L5.24,7.74Z</Geometry>
        <Geometry x:Key="GitHubIconGeometry">M12,2C6.48,2 2,6.58 2,12.26C2,16.78 4.87,20.61 8.84,21.97C9.34,22.07 9.52,21.75 9.52,21.49C9.52,21.25 9.51,20.45 9.51,19.6C6.73,20.22 6.14,18.38 6.14,18.38C5.68,17.18 5.03,16.86 5.03,16.86C4.12,16.22 5.1,16.24 5.1,16.24C6.1,16.31 6.63,17.31 6.63,17.31C7.52,18.87 8.97,18.42 9.54,18.16C9.63,17.5 9.89,17.05 10.17,16.79C7.95,16.53 5.62,15.65 5.62,11.71C5.62,10.59 6,9.68 6.65,8.96C6.55,8.7 6.2,7.65 6.75,6.24C6.75,6.24 7.59,5.96 9.5,7.29C10.3,7.06 11.15,6.95 12,6.95C12.85,6.95 13.7,7.06 14.5,7.29C16.41,5.96 17.25,6.24 17.25,6.24C17.8,7.65 17.45,8.7 17.35,8.96C18,9.68 18.38,10.59 18.38,11.71C18.38,15.66 16.04,16.53 13.82,16.78C14.18,17.1 14.5,17.72 14.5,18.68C14.5,20.05 14.49,21.15 14.49,21.49C14.49,21.75 14.67,22.08 15.18,21.97C19.14,20.61 22,16.78 22,12.26C22,6.58 17.52,2 12,2Z</Geometry>
    </Window.Resources>

    <Border Padding="20"
            Background="#EE101219"
            BorderBrush="#28FFFFFF"
            BorderThickness="1"
            CornerRadius="30"
            MouseLeftButtonDown="HeaderDragArea_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="-20,-20,-20,0"
                    Padding="20,16,20,12"
                    Background="#FA0B0E16"
                    CornerRadius="30,30,0,0"
                    MouseLeftButtonDown="HeaderDragArea_MouseLeftButtonDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="1" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.RowSpan="3"
                          Grid.ColumnSpan="2"
                          Background="Transparent"
                          MouseLeftButtonDown="HeaderDragArea_MouseLeftButtonDown" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               FontSize="16"
                               Foreground="#58AFFF"
                               Text="关于 PaneWorks" />
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Width="38"
                            Height="38"
                            MinWidth="38"
                            MinHeight="38"
                            Margin="0,-6,0,0"
                            Style="{StaticResource CircleIconButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="关闭">
                        <Viewbox Width="15"
                                 Height="15"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path Data="M2,2 L14,14 M14,2 L2,14"
                                  Stroke="{StaticResource PaneTextBrush}"
                                  StrokeEndLineCap="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeThickness="2.4" />
                        </Viewbox>
                    </Button>
                    <Grid Grid.Row="1"
                          Grid.Column="0"
                          HorizontalAlignment="Left"
                          Width="118"
                          Height="2"
                          Background="#58AFFF" />
                    <Border Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Background="#22FFFFFF" />
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  Background="Transparent"
                  MouseLeftButtonDown="HeaderDragArea_MouseLeftButtonDown">
                <StackPanel HorizontalAlignment="Center">
                    <Image Width="62"
                           Height="62"
                           HorizontalAlignment="Center"
                           Source="/PaneWorks.App;component/Assets/PaneWorks.png"
                           Stretch="Uniform" />

                    <StackPanel Margin="0,14,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                        <TextBlock FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="#29D8F2"
                                   Text="Pane" />
                        <TextBlock FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="#FF63F5"
                                   Text="Works" />
                    </StackPanel>

                    <TextBlock Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               FontSize="13"
                               Foreground="#9EA6B8"
                               Text="面向 Windows 的桌面工作区分区与窗口吸附工具" />

                    <StackPanel Margin="0,12,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                        <Border Padding="10,4"
                                Background="#1C2F80ED"
                                BorderBrush="#4D58AFFF"
                                BorderThickness="1"
                                CornerRadius="9">
                            <TextBlock x:Name="VersionTextBlock"
                                       FontSize="13"
                                       Foreground="#58AFFF" />
                        </Border>
                        <Border Margin="10,0,0,0"
                                Padding="10,4"
                                Background="#1A2FA36B"
                                BorderBrush="#552FA36B"
                                BorderThickness="1"
                                CornerRadius="9">
                            <TextBlock FontSize="13"
                                       Foreground="#8FF0B8"
                                       Text="维护者：HaG_Cat" />
                        </Border>
                    </StackPanel>

                    <Border Width="360"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="#2A182234"
                            BorderBrush="#3D58AFFF"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock x:Name="ReleaseHighlightsTitleTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#58AFFF"
                                       Text="当前版本亮点" />
                            <TextBlock x:Name="ReleaseHighlightsTextBlock"
                                       Margin="0,8,0,0"
                                       FontSize="12"
                                       Foreground="#CDD3DF"
                                       LineHeight="19"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="4"
                    Background="#22FFFFFF"
                    Height="1" />

            <StackPanel Grid.Row="6">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="Bold"
                               Foreground="#F7F8FF"
                               Text="开源协议" />
                    <TextBlock Margin="0,12,0,0"
                               FontSize="13"
                               Foreground="#CDD3DF"
                               LineHeight="21"
                               Text="PaneWorks 源码公开维护。具体授权、分发与二次开发规则以 GitHub 仓库中的 LICENSE 文件和 Release 说明为准；如当前仓库尚未附带 LICENSE，请在正式对外授权前补充。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Margin="0,18,0,0">
                    <TextBlock FontSize="18"
                               FontWeight="Bold"
                               Foreground="#F7F8FF"
                               Text="更新与反馈" />

                    <Button x:Name="CheckUpdatesButton"
                            Margin="0,14,0,8"
                            Height="38"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="CheckUpdatesButton_Click">
                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <Viewbox Width="18"
                                     Height="18"
                                     Margin="0,0,10,0"
                                     VerticalAlignment="Center">
                                <Canvas Width="24"
                                        Height="24">
                                    <Path Fill="{StaticResource PaneTextBrush}"
                                          Data="{StaticResource RefreshIconGeometry}" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="检查更新" />
                        </StackPanel>
                    </Button>

                    <Button Height="38"
                            Margin="0,0,0,8"
                            Click="OpenReleasesButton_Click">
                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <Viewbox Width="20"
                                     Height="20"
                                     Margin="0,0,10,0">
                                <Path Fill="{StaticResource PaneTextBrush}"
                                      Data="{StaticResource GitHubIconGeometry}" />
                            </Viewbox>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="GitHub Releases" />
                        </StackPanel>
                    </Button>

                    <Button Height="38"
                            Margin="0,0,0,8"
                            Click="OpenGitHubButton_Click">
                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <Viewbox Width="20"
                                     Height="20"
                                     Margin="0,0,10,0">
                                <Path Fill="{StaticResource PaneTextBrush}"
                                      Data="{StaticResource GitHubIconGeometry}" />
                            </Viewbox>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="GitHub 项目主页" />
                        </StackPanel>
                    </Button>

                    <Button Height="38"
                            Click="OpenIssuesButton_Click">
                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <Viewbox Width="20"
                                     Height="20"
                                     Margin="0,0,10,0">
                                <Path Fill="{StaticResource PaneTextBrush}"
                                      Data="{StaticResource GitHubIconGeometry}" />
                            </Viewbox>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="问题反馈与建议" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock Margin="0,24,0,0"
                           FontSize="12"
                           Foreground="#778092"
                           Text="更新检查基于 GitHub 最新 Release；发现新版本后会打开发布页下载便携包。"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
