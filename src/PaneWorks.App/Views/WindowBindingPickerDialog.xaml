<Window x:Class="PaneWorks.App.Views.WindowBindingPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择窗口绑定"
        Width="620"
        Height="540"
        MinWidth="560"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF131A28">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="15"
                   Foreground="#DCEAFF"
                   Text="从当前打开的桌面窗口里选择一个，绑定到现在选中的区域。" />

        <TextBlock x:Name="RegionTextBlock"
                   Grid.Row="2"
                   Foreground="#9FC7FF"
                   TextWrapping="Wrap" />

        <ListBox x:Name="WindowListBox"
                 Grid.Row="4">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12"
                            Background="Transparent"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PaneTextBrush}"
                                       Text="{Binding ProcessName, StringFormat={}{0}.exe}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#D7E6FF"
                                       Text="{Binding Title}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="6"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="104"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Content="取消" />
            <Button Width="124"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True"
                    Click="ConfirmButton_Click"
                    Content="绑定到区域" />
        </StackPanel>
    </Grid>
</Window>
