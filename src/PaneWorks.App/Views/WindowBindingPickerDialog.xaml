<Window x:Class="PaneWorks.App.Views.WindowBindingPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择窗口绑定"
        Width="700"
        Height="620"
        MinWidth="620"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF131A28">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="15"
                   Foreground="#DCEAFF"
                   Text="从当前已打开的桌面窗口里选择一个，绑定到现在选中的区域。" />

        <TextBlock x:Name="RegionTextBlock"
                   Grid.Row="2"
                   Foreground="#9FC7FF"
                   TextWrapping="Wrap" />

        <Border x:Name="DetectedHintBorder"
                Grid.Row="4"
                Padding="12,10"
                Background="#1E3A8A33"
                BorderBrush="#5B84A6FF"
                BorderThickness="1"
                CornerRadius="14"
                Visibility="Collapsed">
            <TextBlock x:Name="DetectedHintTextBlock"
                       Foreground="#CFE7FF"
                       TextWrapping="Wrap" />
        </Border>

        <ListBox x:Name="WindowListBox"
                 Grid.Row="6">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12"
                            Background="Transparent"
                            CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="36"
                                    Height="36"
                                    CornerRadius="10"
                                    Background="#24334A"
                                    BorderBrush="#3E4E67"
                                    BorderThickness="1">
                                <Grid>
                                    <Image Width="18"
                                           Height="18"
                                           Source="{Binding IconSource}"
                                           Stretch="Uniform">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="#EAF2FF"
                                               Text="{Binding FallbackGlyph}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="2">
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PaneTextBrush}"
                                           Text="{Binding ProcessLabel}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#D7E6FF"
                                           Text="{Binding Title}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="#8FB3E6"
                                           Text="{Binding ExecutablePath}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="8"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="104"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Content="取消" />
            <Button x:Name="ConfirmButton"
                    Width="164"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True"
                    Click="ConfirmButton_Click"
                    Content="绑定到当前区域" />
        </StackPanel>
    </Grid>
</Window>
