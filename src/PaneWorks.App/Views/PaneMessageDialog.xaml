<Window x:Class="PaneWorks.App.Views.PaneMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PaneWorks"
        Width="430"
        MinWidth="430"
        MaxWidth="430"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        TextElement.Foreground="{StaticResource PaneTextBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border Padding="18"
            Background="#EE101219"
            BorderBrush="#28FFFFFF"
            BorderThickness="1"
            CornerRadius="26">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="-18,-18,-18,0"
                    Padding="18,15,18,13"
                    Background="#FA0B0E16"
                    CornerRadius="26,26,0,0"
                    MouseLeftButtonDown="HeaderDragArea_MouseLeftButtonDown">
                <Grid Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">
                        <Border x:Name="KindBadge"
                                Width="28"
                                Height="28"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Background="#242F80ED"
                                BorderBrush="#6658AFFF"
                                BorderThickness="1"
                                CornerRadius="14">
                            <TextBlock x:Name="KindTextBlock"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#58AFFF"
                                       Text="i" />
                        </Border>
                        <TextBlock x:Name="TitleTextBlock"
                                   VerticalAlignment="Center"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#F7F8FF"
                                   Text="PaneWorks" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="36"
                            Height="36"
                            MinWidth="36"
                            MinHeight="36"
                            Margin="8,-4,0,-4"
                            Style="{StaticResource CircleIconButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="关闭">
                        <Viewbox Width="14"
                                 Height="14">
                            <Path Data="M2,2 L14,14 M14,2 L2,14"
                                  Stroke="{StaticResource PaneTextBrush}"
                                  StrokeEndLineCap="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeThickness="2.4" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <TextBlock x:Name="MessageTextBlock"
                       Grid.Row="2"
                       FontSize="15"
                       Foreground="#E8EEF9"
                       LineHeight="25"
                       TextWrapping="Wrap" />

            <StackPanel x:Name="ButtonPanel"
                        Grid.Row="4"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal" />
        </Grid>
    </Border>
</Window>
