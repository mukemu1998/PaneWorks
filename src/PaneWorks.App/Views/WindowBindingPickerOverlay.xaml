<UserControl x:Class="PaneWorks.App.Views.WindowBindingPickerOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="640"
             Height="610"
             Visibility="Collapsed"
             TextElement.Foreground="{StaticResource PaneTextBrush}">
    <Border Background="#FF101219"
            BorderBrush="#4AFFFFFF"
            BorderThickness="1"
            CornerRadius="28">
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Width="28" Height="28" Margin="0,0,10,0" Background="#1B2F80ED" BorderBrush="#5158AFFF" BorderThickness="1" CornerRadius="9">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#58AFFF" Text="PW" />
                    </Border>
                    <TextBlock VerticalAlignment="Center" FontSize="19" FontWeight="SemiBold" Foreground="#F7F8FF" Text="选择窗口绑定" />
                </StackPanel>
                <Button Grid.Column="1" Width="36" Height="36" MinWidth="36" MinHeight="36" Style="{StaticResource CircleIconButtonStyle}" Click="CloseButton_Click" ToolTip="关闭">
                    <Viewbox Width="14" Height="14">
                        <Path Data="M2,2 L14,14 M14,2 L2,14" Stroke="{StaticResource PaneTextBrush}" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeThickness="2.4" />
                    </Viewbox>
                </Button>
            </Grid>

            <StackPanel Grid.Row="2">
                <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="#E7F0FF" Text="从当前已打开的桌面窗口中选择一个，绑定到选中的区域。" />
                <TextBlock x:Name="RegionTextBlock" Margin="0,8,0,0" FontSize="12.5" Foreground="#7FB4FF" TextWrapping="Wrap" />
                <Border x:Name="DetectedHintBorder" Margin="0,12,0,0" Padding="12,10" Background="#1E3A8A33" BorderBrush="#5B84A6FF" BorderThickness="1" CornerRadius="14" Visibility="Collapsed">
                    <TextBlock x:Name="DetectedHintTextBlock" Foreground="#CFE7FF" TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <Border Grid.Row="4" Padding="8" Background="#80101625" BorderBrush="#38587A" BorderThickness="1" CornerRadius="18">
                <ListBox x:Name="WindowListBox" Padding="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False" PreviewMouseWheel="WindowListBox_PreviewMouseWheel">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" Background="Transparent" CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="10" Background="#24334A" BorderBrush="#3E4E67" BorderThickness="1">
                                        <Grid>
                                            <Image Width="18" Height="18" Source="{Binding IconSource}" Stretch="Uniform">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#EAF2FF" Text="{Binding FallbackGlyph}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PaneTextBrush}" Text="{Binding ProcessLabel}" />
                                        <TextBlock Margin="0,4,0,0" Foreground="#D7E6FF" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#8FB3E6" Text="{Binding ExecutablePath}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <StackPanel Grid.Row="6" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Width="104" Margin="0,0,10,0" Click="CloseButton_Click" Content="取消" />
                <Button x:Name="ConfirmButton" Width="164" Style="{StaticResource PrimaryButtonStyle}" Click="ConfirmButton_Click" Content="绑定到当前区域" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
