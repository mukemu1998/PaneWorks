<Window x:Class="PaneWorks.App.Updates.UpdateProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PaneWorks 更新"
        Width="410"
        MinWidth="410"
        MaxWidth="410"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent"
        TextElement.Foreground="{StaticResource PaneTextBrush}">
    <Border Padding="20"
            Background="#EE101219"
            BorderBrush="#3D58AFFF"
            BorderThickness="1"
            CornerRadius="26">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="-20,-20,-20,0"
                    Padding="20,15,20,13"
                    Background="#FA0B0E16"
                    CornerRadius="26,26,0,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="28"
                            Height="28"
                            Margin="0,0,10,0"
                            Background="#242F80ED"
                            BorderBrush="#6658AFFF"
                            BorderThickness="1"
                            CornerRadius="14">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#58AFFF"
                                   Text="↑" />
                    </Border>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#F7F8FF"
                               Text="PaneWorks 更新" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2">
                <TextBlock x:Name="StatusTextBlock"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#F7F8FF"
                           Text="正在准备更新" />
                <TextBlock x:Name="DetailTextBlock"
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#AEB8C8"
                           TextWrapping="Wrap"
                           Text="正在连接更新服务器。" />
            </StackPanel>

            <StackPanel Grid.Row="4">
                <ProgressBar x:Name="DownloadProgressBar"
                             Height="10"
                             Minimum="0"
                             Maximum="100"
                             Value="0" />
                <TextBlock x:Name="ProgressTextBlock"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Right"
                           FontSize="12"
                           Foreground="#58AFFF"
                           Text="0%" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
