<Window x:Class="PaneWorks.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:PaneWorks.App.Controls"
        xmlns:views="clr-namespace:PaneWorks.App.Views"
        mc:Ignorable="d"
        Title="PaneWorks"
        Width="1600"
        Height="960"
        MinWidth="1280"
        MinHeight="760"
        Icon="Assets/PaneWorks.png"
        WindowState="Normal"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        PreviewMouseLeftButtonDown="MainWindow_PreviewMouseLeftButtonDown">
    <Grid Background="{x:Null}">
        <Border Background="#28101625"
                IsHitTestVisible="False"
                Visibility="{Binding DesktopOverlayVisibility}" />

        <controls:EditorCanvasControl x:Name="EditorCanvas"
                                      Visibility="{Binding DesktopOverlayVisibility}"
                                      Document="{Binding CurrentDocument}"
                                      SelectedNodeId="{Binding SelectedNodeId}"
                                      AvailableLayouts="{Binding Layouts}"
                                      ActiveSnapLayoutId="{Binding ActiveSnapLayoutId}"
                                      AvailableWorkspaceProfiles="{Binding WorkspaceProfiles}"
                                      ActiveWorkspaceProfileId="{Binding ActiveWorkspaceProfileId}"
                                      IsLayoutEditingEnabled="{Binding IsLayoutEditMode}"
                                      ShowWorkspaceBindingMarkers="{Binding IsWorkspaceBindingMode}"
                                      BindingDisplayId="{Binding SelectedDisplayItem.Id}"
                                      EditingDisplayName="{Binding CurrentDisplayName}"
                                      WorkspaceWindowBindings="{Binding ActiveWorkspaceWindowBindings}" />

        <Grid x:Name="WorkbenchPanel"
              Width="820"
              MaxHeight="680"
              Background="Transparent"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              TextElement.Foreground="{StaticResource PaneTextBrush}">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="WorkbenchPanelTranslate" />
            </Grid.RenderTransform>

            <Border Background="#EE101219"
                    BorderBrush="#28FFFFFF"
                    BorderThickness="1"
                    CornerRadius="30"
                    IsHitTestVisible="False" />

            <Border Height="92"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    MouseLeftButtonDown="WorkbenchDragHandle_MouseLeftButtonDown"
                    MouseLeftButtonUp="WorkbenchDragHandle_MouseLeftButtonUp"
                    MouseMove="WorkbenchDragHandle_MouseMove" />

            <Grid Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                    <Grid Background="Transparent"
                          MouseLeftButtonDown="WorkbenchDragHandle_MouseLeftButtonDown"
                          MouseLeftButtonUp="WorkbenchDragHandle_MouseLeftButtonUp"
                          MouseMove="WorkbenchDragHandle_MouseMove">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              Grid.ColumnSpan="2"
                              Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0"
                                   Width="54"
                                   Height="54"
                                   Margin="0,0,14,0"
                                   VerticalAlignment="Center"
                                   Source="Assets/PaneWorks.png"
                                   Stretch="Uniform" />

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal"
                                            IsHitTestVisible="False">
                                    <TextBlock FontSize="25"
                                               FontWeight="Bold"
                                               Foreground="#29D8F2"
                                               Text="Pane" />
                                    <TextBlock FontSize="25"
                                               FontWeight="Bold"
                                               Foreground="#FF63F5"
                                               Text="Works" />
                                    <TextBlock Margin="8,0,0,0"
                                               FontSize="25"
                                               FontWeight="Bold"
                                               Foreground="#F7F8FF"
                                               Text="布局工作台" />
                                    <Border Margin="10,4,0,0"
                                            Padding="8,3"
                                            VerticalAlignment="Center"
                                            Background="#1C2F80ED"
                                            BorderBrush="#4D58AFFF"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#58AFFF"
                                                   Text="{Binding AppVersionLabel}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="13"
                                           Foreground="#9EA6B8"
                                           IsHitTestVisible="False"
                                           Text="透明桌面分割层，管理吸附布局；需要窗口绑定时再展开高级工作区。"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Column="3"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Orientation="Horizontal">
                            <Button Style="{StaticResource CircleIconButtonStyle}"
                                    Width="42"
                                    Height="42"
                                    MinWidth="42"
                                    MinHeight="42"
                                    Margin="0,0,8,8"
                                    Background="#18FFFFFF"
                                    BorderBrush="#30FFFFFF"
                                    FontSize="18"
                                    Click="AboutButton_Click"
                                    ToolTip="关于 PaneWorks">
                                <TextBlock Width="20"
                                           Height="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           LineHeight="20"
                                           LineStackingStrategy="BlockLineHeight"
                                           Text="i"
                                           TextAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource CircleIconButtonStyle}"
                                    Width="42"
                                    Height="42"
                                    MinWidth="42"
                                    MinHeight="42"
                                    Margin="0,0,8,8"
                                    Background="#18FFFFFF"
                                    BorderBrush="#30FFFFFF"
                                    Click="SettingsButton_Click"
                                    ToolTip="设置">
                                <Grid Width="42"
                                      Height="42"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False"
                                      SnapsToDevicePixels="True">
                                    <Viewbox Width="21"
                                             Height="21"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Canvas Width="24"
                                                Height="24">
                                            <Path Fill="{StaticResource PaneTextBrush}"
                                                  Data="M19.43,12.98C19.47,12.66 19.5,12.34 19.5,12C19.5,11.66 19.47,11.33 19.42,11L21.54,9.35C21.73,9.2 21.78,8.93 21.66,8.71L19.66,5.25C19.54,5.03 19.29,4.94 19.06,5.03L16.56,6.04C16.04,5.64 15.5,5.31 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.31 7.96,5.65 7.44,6.04L4.94,5.03C4.71,4.95 4.46,5.03 4.34,5.25L2.34,8.71C2.21,8.93 2.27,9.2 2.46,9.35L4.58,11C4.53,11.33 4.5,11.66 4.5,12C4.5,12.34 4.53,12.66 4.58,12.98L2.46,14.65C2.27,14.8 2.22,15.07 2.34,15.29L4.34,18.75C4.46,18.97 4.71,19.06 4.94,18.97L7.44,17.96C7.96,18.36 8.5,18.69 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.69 16.04,18.35 16.56,17.96L19.06,18.97C19.29,19.05 19.54,18.97 19.66,18.75L21.66,15.29C21.78,15.07 21.73,14.8 21.54,14.65L19.43,12.98ZM12,15.5A3.5,3.5 0 1,1 12,8A3.5,3.5 0 0,1 12,15.5Z" />
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource CircleIconButtonStyle}"
                                    Width="42"
                                    Height="42"
                                    MinWidth="42"
                                    MinHeight="42"
                                    Margin="0,0,8,8"
                                    Click="SidebarWorkbenchButton_Click"
                                    ToolTip="收起为侧边悬浮条">
                                <TextBlock Width="22"
                                           Height="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="19"
                                           LineHeight="22"
                                           LineStackingStrategy="BlockLineHeight"
                                           Text="⇥"
                                           TextAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource CircleIconButtonStyle}"
                                    Width="42"
                                    Height="42"
                                    MinWidth="42"
                                    MinHeight="42"
                                    Margin="0,0,8,8"
                                    Click="MinimizeWorkbenchButton_Click"
                                    ToolTip="最小化到任务栏">
                                <TextBlock Width="22"
                                           Height="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           LineHeight="20"
                                           LineStackingStrategy="BlockLineHeight"
                                           Text="－"
                                           TextAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource CircleIconButtonStyle}"
                                    Width="42"
                                    Height="42"
                                    MinWidth="42"
                                    MinHeight="42"
                                    Margin="0,0,0,8"
                                    Click="CloseWorkbenchButton_Click"
                                    ToolTip="退出到托盘">
                                <TextBlock Width="22"
                                           Height="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="20"
                                           LineHeight="22"
                                           LineStackingStrategy="BlockLineHeight"
                                           Text="×"
                                           TextAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </Grid>

                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              PanningMode="VerticalOnly">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="0"
                            Background="#A0101219"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="22">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ToggleButton x:Name="SnapLayoutSettingsToggle"
                                          IsChecked="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          FocusVisualStyle="{x:Null}"
                                          Focusable="False"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="HeaderBorder"
                                                Padding="16,14"
                                                Background="Transparent"
                                                CornerRadius="22">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock FontSize="18"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PaneTextBrush}"
                                                               Text="吸附布局设置" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               FontSize="12"
                                                               Foreground="#9EA6B8"
                                                               Text="选择、编辑并管理窗口吸附使用的分区布局。" />
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        Width="34"
                                                        Height="34"
                                                        VerticalAlignment="Center"
                                                        Background="#18FFFFFF"
                                                        BorderBrush="#30FFFFFF"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Grid HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Width="14"
                                                          Height="10">
                                                        <Path x:Name="ArrowCollapsed"
                                                              Data="M 0 0 L 7 8 L 14 0 Z"
                                                              Fill="{StaticResource PaneTextBrush}"
                                                              Stretch="Uniform" />
                                                        <Path x:Name="ArrowExpanded"
                                                              Data="M 0 8 L 7 0 L 14 8 Z"
                                                              Fill="{StaticResource PaneTextBrush}"
                                                              Stretch="Uniform"
                                                              Visibility="Collapsed" />
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HeaderBorder" Property="Background" Value="#122F80ED" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ArrowCollapsed" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="ArrowExpanded" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Grid Grid.Row="1"
                                  Margin="16,8,16,16">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=SnapLayoutSettingsToggle}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontSize="20"
                                               FontWeight="SemiBold"
                                               Text="编辑与保存" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#CDD3DF"
                                               Text="{Binding StatusLine}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,14,0,0"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#F7F8FF"
                                               Text="编辑操作指引" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#AEB8C8"
                                               Text="先点击“新建分区”或“编辑当前选择”，也可以先选中一个已保存分区再点“打开编辑”，进入编辑后再按下面 3 步操作。"
                                               TextWrapping="Wrap" />
                                    <UniformGrid Margin="0,10,0,0"
                                                  Columns="3">
                                        <Border Margin="0,0,8,0"
                                                Padding="12"
                                                Background="#1C2F80ED"
                                                BorderBrush="#4D58AFFF"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <StackPanel>
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PaneTextBrush}"
                                                           Text="1. 创建分割线" />
                                                <TextBlock Margin="0,5,0,0"
                                                           FontSize="12"
                                                           Foreground="#D7E6FF"
                                                           Text="右键空白区域，选择横向或纵向二等分、三等分；后续还能继续右键切分。"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="4,0,4,0"
                                                Padding="12"
                                                 Background="#1A29D8F2"
                                                 BorderBrush="#4D29D8F2"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <StackPanel>
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PaneTextBrush}"
                                                           Text="2. 拖动调比例" />
                                                <TextBlock Margin="0,5,0,0"
                                                           FontSize="12"
                                                           Foreground="#D7E6FF"
                                                           Text="拖动黄色分割线实时调整区域大小，蓝色表示当前选中的分割线。"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="8,0,0,0"
                                                Padding="12"
                                                 Background="#1458AFFF"
                                                 BorderBrush="#3D58AFFF"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <StackPanel>
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PaneTextBrush}"
                                                           Text="3. 删除分割线" />
                                                <TextBlock Margin="0,5,0,0"
                                                           FontSize="12"
                                                           Foreground="#D7E6FF"
                                                           Text="右键分割线选择删除，相邻区域会自动合并成更大的可用区域。"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Margin="16,2,0,0"
                                           Foreground="#8FF0B8"
                                           Text="{Binding DirtyLabel}" />
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="230" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="13"
                                               Foreground="#58AFFF"
                                               Text="编辑屏幕" />
                                    <Border Margin="0,8,0,0"
                                            Padding="12,9"
                                            Background="#1AFFFFFF"
                                            BorderBrush="#3FFFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding CurrentDisplayName}" />
                                            <TextBlock Margin="0,3,0,0"
                                                       FontSize="12"
                                                       Foreground="#D7E6FF"
                                                       Text="{Binding CurrentDisplaySummary}" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="#F0AAAD"
                                               Text="进入编辑后，点击其他屏幕区域即可切换编辑屏幕。"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="13"
                                               Foreground="#58AFFF"
                                               Text="当前吸附选择的分区布局" />
                                    <TextBox Margin="0,8,0,0"
                                             FontSize="20"
                                             FontWeight="SemiBold"
                                             IsReadOnly="{Binding IsLayoutNameReadOnly}"
                                             Text="{Binding DisplayedLayoutName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="#8FF0B8"
                                               Text="{Binding LayoutEditModeLabel}" />
                                    <TextBlock Margin="0,5,0,0"
                                               FontSize="12"
                                               Foreground="#CDD3DF"
                                               Text="{Binding LayoutEditModeHint}"
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <Button MinWidth="98"
                                                Margin="0,0,8,8"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding SaveLayoutCommand}"
                                                Content="保存分区" />
                                        <Button MinWidth="98"
                                                Margin="0,0,8,8"
                                                Command="{Binding SaveAsLayoutCommand}"
                                                Content="另存分区" />
                                        <Button MinWidth="98"
                                                Margin="0,0,8,8"
                                                Command="{Binding NewLayoutCommand}"
                                                Content="新建分区" />
                                        <Button MinWidth="116"
                                                Margin="0,0,8,8"
                                                Command="{Binding EditActiveSnapLayoutCommand}"
                                                Content="编辑当前选择" />
                                        <Button MinWidth="98"
                                                Margin="0,0,0,8"
                                                Style="{StaticResource ExitEditButtonStyle}"
                                                Command="{Binding ExitLayoutEditModeCommand}"
                                                Content="退出编辑" />
                                    </WrapPanel>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Padding="14"
                                        Background="#66101219"
                                        BorderBrush="#20FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="17"
                                                   FontWeight="SemiBold"
                                                   Text="已保存分区布局" />
                                        <WrapPanel Grid.Row="1"
                                                   Margin="0,12,0,10">
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource SuccessButtonStyle}"
                                                    Command="{Binding SetSelectedLayoutAsSnapLayoutCommand}"
                                                    Content="设为当前吸附" />
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource OpenLayoutEditButtonStyle}"
                                                    Command="{Binding LoadSelectedLayoutCommand}"
                                                    Content="打开编辑" />
                                            <Button Margin="0,0,0,8"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Command="{Binding DeleteSelectedLayoutCommand}"
                                                    Content="删除" />
                                        </WrapPanel>

                                        <ListBox Grid.Row="2"
                                                 MaxHeight="150"
                                                 IsHitTestVisible="{Binding IsLayoutListSelectionEnabled}"
                                                 Focusable="False"
                                                 ItemsSource="{Binding Layouts}"
                                                 SelectedItem="{Binding SelectedLayoutItem}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10"
                                                            Background="Transparent"
                                                            CornerRadius="14">
                                                        <StackPanel>
                                                            <TextBlock FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Name}" />
                                                            <TextBlock Margin="0,5,0,0"
                                                                       Foreground="#CBE0FF"
                                                                       Text="{Binding Description}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Padding="14"
                                        Background="#66101219"
                                        BorderBrush="#20FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <StackPanel>
                                        <TextBlock FontSize="17"
                                                   FontWeight="SemiBold"
                                                   Text="当前吸附状态" />
                                        <TextBlock Margin="0,12,0,0"
                                                   Foreground="#8FF0B8"
                                                   Text="{Binding SnapLayoutLabel}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,9,0,0"
                                                   Foreground="#D7E6FF"
                                                   Text="{Binding SelectionLabel}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="#8DBBFF"
                                                       Text="快捷操作" />
                                            <TextBlock Margin="0,5,0,0"
                                                       Foreground="#D7E6FF">
                                                <Run Text="用户分区吸附：拖动窗口时按住 " />
                                                <Run Foreground="#58AFFF"
                                                     Text="{Binding SavedLayoutSnapShortcutLabel, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#D7E6FF">
                                                <Run Text="临时调整区吸附：拖动窗口时按住 " />
                                                <Run Foreground="#58AFFF"
                                                     Text="{Binding TemporarySnapShortcutLabel, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#D7E6FF">
                                                <Run Text="收进托盘：" />
                                                <Run Foreground="#58AFFF"
                                                     Text="{Binding MinimizeShortcutLabel, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#D7E6FF">
                                                <Run Text="开机自启：" />
                                                <Run Foreground="#8FF0B8"
                                                     Text="{Binding StartupStatusLabel, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Margin="0,12,0,0"
                                                Padding="10"
                                                Background="#24154870"
                                                BorderBrush="#4A58AFFF"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="#83B8FF"
                                                           Text="临时吸附说明" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Foreground="#C8D8F4"
                                                           Text="区域中央：按当前临时布局正常吸附；靠近区域上下左右边缘：插入窗口并二等分该区域。"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="#C8D8F4"
                                                           Text="拖到只连接两个区域的分割线：在两侧之间三等分插入；现有窗口会同步调整并保持联动。"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="#8FF0B8"
                                                           Text="临时吸附只在本次 PaneWorks 运行中有效，不会改写已保存的分区布局。"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <WrapPanel Margin="0,14,0,0">
                                            <Button x:Name="PauseSnapAssistButton"
                                                    Margin="0,0,8,8"
                                                    MinWidth="116"
                                                    Click="PauseSnapAssistButton_Click"
                                                    Content="暂停吸附" />
                                            <Button Margin="0,0,0,8"
                                                    MinWidth="150"
                                                    Click="ResetSnapSessionButton_Click"
                                                    Content="重置会话吸附" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="#88101219"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="22">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ToggleButton x:Name="WorkspaceAdvancedToggle"
                                          IsChecked="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          FocusVisualStyle="{x:Null}"
                                          Focusable="False"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="HeaderBorder"
                                                Padding="16,14"
                                                Background="Transparent"
                                                CornerRadius="22">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock FontSize="18"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PaneTextBrush}"
                                                               Text="工作区方案设置（高级编辑）" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               FontSize="12"
                                                Foreground="#9EA6B8"
                                                               Text="用于绑定窗口、启动软件并恢复到指定区域。" />
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        Width="34"
                                                        Height="34"
                                                        VerticalAlignment="Center"
                                                        Background="#18FFFFFF"
                                                        BorderBrush="#30FFFFFF"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Grid HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Width="14"
                                                          Height="10">
                                                        <Path x:Name="ArrowCollapsed"
                                                              Data="M 0 0 L 7 8 L 14 0 Z"
                                                              Fill="{StaticResource PaneTextBrush}"
                                                              Stretch="Uniform" />
                                                        <Path x:Name="ArrowExpanded"
                                                              Data="M 0 8 L 7 0 L 14 8 Z"
                                                              Fill="{StaticResource PaneTextBrush}"
                                                              Stretch="Uniform"
                                                              Visibility="Collapsed" />
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HeaderBorder" Property="Background" Value="#122F80ED" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ArrowCollapsed" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="ArrowExpanded" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Grid Grid.Row="1"
                                  Margin="16,8,16,16">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=WorkspaceAdvancedToggle}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="14"
                                    Background="#66101219"
                                    BorderBrush="#20FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock FontSize="17"
                                               FontWeight="SemiBold"
                                               Text="工作区方案" />
                                    <TextBlock Grid.Row="1"
                                               Margin="0,10,0,0"
                                               Foreground="#58AFFF"
                                               Text="{Binding WorkspaceProfileLabel}"
                                               TextWrapping="Wrap" />

                                    <WrapPanel Grid.Row="2"
                                               Margin="0,12,0,10">
                                        <Button Margin="0,0,8,8"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                IsEnabled="{Binding CanManageSelectedWorkspaceProfile}"
                                                Click="ActivateSelectedWorkspaceProfileButton_Click"
                                                Content="应用选中工作区" />
                                        <Button Margin="0,0,8,8"
                                                Command="{Binding CreateWorkspaceProfileFromCurrentLayoutCommand}"
                                                Content="从当前吸附创建" />
                                        <Button Margin="0,0,8,8"
                                                Command="{Binding NewWorkspaceProfileCommand}"
                                                Content="从选中分区创建" />
                                        <Button Margin="0,0,8,8"
                                                Style="{StaticResource OpenWorkspaceBindingButtonStyle}"
                                                Command="{Binding BeginWorkspaceBindingModeCommand}"
                                                Content="编辑绑定" />
                                        <Button Margin="0,0,8,8"
                                                Style="{StaticResource ExitWorkspaceBindingButtonStyle}"
                                                Command="{Binding ExitWorkspaceBindingModeCommand}"
                                                Content="退出绑定" />
                                        <Button Margin="0,0,8,8"
                                                Click="RefreshWorkspaceProfilesButton_Click"
                                                IsEnabled="{Binding IsWorkspaceProfileListSelectionEnabled}"
                                                Content="刷新状态" />
                                        <Button Margin="0,0,8,8"
                                                Command="{Binding SaveWorkspaceProfileCommand}"
                                                Content="保存" />
                                        <Button Margin="0,0,8,8"
                                                Command="{Binding SaveAsWorkspaceProfileCommand}"
                                                Content="另存" />
                                        <Button Margin="0,0,0,8"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Command="{Binding DeleteSelectedWorkspaceProfileCommand}"
                                                Content="删除" />
                                    </WrapPanel>

                                    <ListBox Grid.Row="3"
                                             MaxHeight="150"
                                             IsHitTestVisible="{Binding IsWorkspaceProfileListSelectionEnabled}"
                                             Focusable="False"
                                             ItemsSource="{Binding WorkspaceProfiles}"
                                             SelectedItem="{Binding SelectedWorkspaceProfileItem}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10"
                                                        Background="Transparent"
                                                        CornerRadius="14">
                                                    <StackPanel>
                                                        <TextBlock FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Name}" />
                                                        <TextBlock Margin="0,5,0,0"
                                                                   Text="{Binding Description}"
                                                                   TextWrapping="Wrap">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#CBE0FF" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEmptyWorkspaceBinding}" Value="True">
                                                                            <Setter Property="Foreground" Value="#FF8A8A" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding HasWorkspaceBinding}" Value="True">
                                                                            <Setter Property="Foreground" Value="#7DFFB2" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding HasWorkspaceWarning}" Value="True">
                                                                            <Setter Property="Foreground" Value="#FFCC66" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="14"
                                    Background="#66131A28"
                                    BorderBrush="#20FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock FontSize="17"
                                               FontWeight="SemiBold"
                                               Text="区域窗口绑定" />
                                    <TextBlock Margin="0,12,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="#8FF0B8"
                                               Text="{Binding SelectedRegionBindingSummary}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,9,0,0"
                                               Foreground="#D7E6FF"
                                               Text="{Binding SelectedRegionBindingDescription}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,9,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="#58AFFF"
                                               Text="{Binding WorkspaceBindingModeLabel}"
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <Button Margin="0,0,8,8"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                IsEnabled="{Binding CanEditWorkspaceBindings}"
                                                Click="BindWindowButton_Click"
                                                Content="手动绑定窗口" />
                                        <Button Margin="0,0,8,8"
                                                Style="{StaticResource SuccessButtonStyle}"
                                                IsEnabled="{Binding CanEditWorkspaceBindings}"
                                                Click="AutoBindSnappedWindowsButton_Click"
                                                Content="一键绑定已吸附" />
                                        <Button Margin="0,0,8,8"
                                                Style="{StaticResource DangerButtonStyle}"
                                                IsEnabled="{Binding CanEditWorkspaceBindings}"
                                                Click="ClearWindowBindingButton_Click"
                                                Content="清除选中绑定" />
                                        <Button Margin="0,0,0,8"
                                                Style="{StaticResource DangerButtonStyle}"
                                                IsEnabled="{Binding CanEditWorkspaceBindings}"
                                                Click="ClearAllWindowBindingsButton_Click"
                                                Content="清除全部绑定" />
                                    </WrapPanel>
                                    <Border Margin="0,8,0,0"
                                            Padding="12"
                                            Background="#161D3150"
                                            BorderBrush="#264F78A8"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="#B7D9FF"
                                                       Text="方案绑定预览" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="#9EAFC7"
                                                       Text="{Binding SelectedWorkspaceProfileBindingPreviewLabel}"
                                                       TextWrapping="Wrap" />
                                            <ItemsControl Margin="0,10,0,0"
                                                          ItemsSource="{Binding SelectedWorkspaceProfileWindowBindings}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="42"
                                                                Height="42"
                                                                Margin="0,0,8,8"
                                                                Background="#20334A"
                                                                BorderBrush="#3E5A7D"
                                                                BorderThickness="1"
                                                                CornerRadius="12"
                                                                ToolTip="{Binding DisplayName}">
                                                            <Grid>
                                                                <Image Width="22"
                                                                       Height="22"
                                                                       Source="{Binding IconSource}"
                                                                       Stretch="Uniform">
                                                                    <Image.Style>
                                                                        <Style TargetType="Image">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Image.Style>
                                                                </Image>
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontWeight="Bold"
                                                                           Foreground="#EAF2FF"
                                                                           Text="{Binding FallbackGlyph}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4"
                            Padding="14,12"
                            Background="#80131A28"
                            BorderBrush="#20FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18"
                            IsHitTestVisible="False">
                        <TextBlock Foreground="#58AFFF"
                                   Text="提示：右键区域继续切分，右键分割线删除分割；“切换吸附布局”只影响后续用户分区吸附，“工作区方案”用于窗口绑定和自动恢复。"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
                </ScrollViewer>
            </Grid>
            <views:WindowBindingPickerOverlay x:Name="WindowBindingPickerOverlay"
                                              Panel.ZIndex="20"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
        </Grid>

        <Button x:Name="WorkbenchMiniBar"
                Width="62"
                Height="106"
                Margin="0,0,14,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Background="#EE101219"
                BorderBrush="#42FFFFFF"
                BorderThickness="1"
                Cursor="Hand"
                PreviewMouseLeftButtonDown="WorkbenchMiniBar_PreviewMouseLeftButtonDown"
                PreviewMouseMove="WorkbenchMiniBar_PreviewMouseMove"
                PreviewMouseLeftButtonUp="WorkbenchMiniBar_PreviewMouseLeftButtonUp"
                ToolTip="展开 PaneWorks 主菜单"
                Visibility="Collapsed">
            <Button.RenderTransform>
                <TranslateTransform x:Name="WorkbenchMiniBarTranslate" />
            </Button.RenderTransform>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="MiniBarBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="20">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MiniBarBorder" Property="Background" Value="#E01D2638" />
                            <Setter TargetName="MiniBarBorder" Property="BorderBrush" Value="#7D9FC7FF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MiniBarBorder" Property="Opacity" Value="0.82" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Image Width="34"
                       Height="34"
                       Source="Assets/PaneWorks.png"
                       Stretch="Uniform" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PaneTextBrush}"
                           Text="展开"
                           TextAlignment="Center" />
            </StackPanel>
        </Button>
    </Grid>
</Window>
