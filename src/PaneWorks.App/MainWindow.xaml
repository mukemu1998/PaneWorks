<Window x:Class="PaneWorks.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:PaneWorks.App.Controls"
        mc:Ignorable="d"
        Title="PaneWorks"
        Width="1600"
        Height="960"
        MinWidth="1280"
        MinHeight="760"
        WindowState="Normal"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#120A1222" Offset="0" />
                <GradientStop Color="#210F1B30" Offset="0.5" />
                <GradientStop Color="#12060B17" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <controls:EditorCanvasControl x:Name="EditorCanvas"
                                      Document="{Binding CurrentDocument}"
                                      SelectedNodeId="{Binding SelectedNodeId}"
                                      AvailableLayouts="{Binding Layouts}"
                                      ActiveSnapLayoutId="{Binding ActiveSnapLayoutId}" />

        <Grid x:Name="WorkbenchPanel"
              Width="1120"
              MaxWidth="1180"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              TextElement.Foreground="{StaticResource PaneTextBrush}">
            <Border Background="#C9151B2A"
                    BorderBrush="#42FFFFFF"
                    BorderThickness="1"
                    CornerRadius="30"
                    IsHitTestVisible="False" />

            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,20,0">
                            <TextBlock FontSize="30"
                                       FontWeight="Bold"
                                       IsHitTestVisible="False"
                                       Text="PaneWorks 布局工作台" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="14"
                                       Foreground="#CFE7FF"
                                       IsHitTestVisible="False"
                                       Text="在桌面透明分割层上直接编辑布局，右键即可继续切分、删除分割、或快速切换吸附布局。"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <WrapPanel Grid.Column="2"
                                   Width="520"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Top"
                                   ItemWidth="100"
                                   Orientation="Horizontal">
                            <Button Margin="0,0,10,10"
                                    Command="{Binding UndoCommand}"
                                    Content="撤销" />
                            <Button Margin="0,0,10,10"
                                    Command="{Binding RedoCommand}"
                                    Content="重做" />
                            <Button Margin="0,0,10,10"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SaveLayoutCommand}"
                                    Content="保存" />
                            <Button Margin="0,0,10,10"
                                    Command="{Binding SaveAsLayoutCommand}"
                                    Content="另存为" />
                            <Button Margin="0,0,10,10"
                                    Command="{Binding NewLayoutCommand}"
                                    Content="新建布局" />
                            <Button Margin="0,0,0,10"
                                    Click="SettingsButton_Click"
                                    Content="设置" />
                        </WrapPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock FontSize="13"
                                       Foreground="#9FC7FF"
                                       IsHitTestVisible="False"
                                       Text="编辑屏幕" />
                            <ComboBox Margin="0,8,0,0"
                                      ItemsSource="{Binding Displays}"
                                      SelectedItem="{Binding SelectedDisplayItem}"
                                      MaxDropDownHeight="360">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2,0">
                                            <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PaneTextBrush}"
                                                       Text="{Binding Name}" />
                                            <TextBlock Margin="0,3,0,0"
                                                       FontSize="12"
                                                       Foreground="#D7E6FF"
                                                       Text="{Binding Description}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#D7E6FF"
                                       IsHitTestVisible="False"
                                       Text="{Binding CurrentDisplaySummary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock FontSize="13"
                                       Foreground="#9FC7FF"
                                       IsHitTestVisible="False"
                                       Text="布局名称" />
                            <TextBox Margin="0,8,0,0"
                                     FontSize="24"
                                     FontWeight="SemiBold"
                                     Text="{Binding CurrentLayoutName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#D7E6FF"
                                       IsHitTestVisible="False"
                                       Text="{Binding StatusLine}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.08*" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="0.92*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="20"
                            Background="#90101625"
                            BorderBrush="#24FFFFFF"
                            BorderThickness="1"
                            CornerRadius="22">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="22"
                                       FontWeight="SemiBold"
                                       Text="已保存布局" />
                            <WrapPanel Grid.Row="1"
                                       Margin="0,18,0,14">
                                <Button Margin="0,0,10,10"
                                        Style="{StaticResource SuccessButtonStyle}"
                                        Command="{Binding SetSelectedLayoutAsSnapLayoutCommand}"
                                        Content="设为吸附布局" />
                                <Button Margin="0,0,10,10"
                                        Command="{Binding LoadSelectedLayoutCommand}"
                                        Content="打开编辑" />
                                <Button Margin="0,0,0,10"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding DeleteSelectedLayoutCommand}"
                                        Content="删除" />
                            </WrapPanel>

                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding Layouts}"
                                     SelectedItem="{Binding SelectedLayoutItem}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14"
                                                Background="Transparent"
                                                CornerRadius="14">
                                            <StackPanel>
                                                <TextBlock FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Name}" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Foreground="#CBE0FF"
                                                           Text="{Binding Description}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <Border Padding="20"
                                Background="#90101625"
                                BorderBrush="#24FFFFFF"
                                BorderThickness="1"
                                CornerRadius="22"
                                IsHitTestVisible="False">
                            <StackPanel>
                                <TextBlock FontSize="22"
                                           FontWeight="SemiBold"
                                           Text="当前状态" />
                                <TextBlock Margin="0,16,0,0"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Text="{Binding DirtyLabel}" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="#BFF7C7"
                                           Text="{Binding SnapLayoutLabel}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="#D7E6FF"
                                           Text="{Binding SelectionLabel}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="#A9C8FF"
                                           Text="{Binding ShortcutSummary}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,18,0,0"
                                Padding="20"
                                Background="#90101625"
                                BorderBrush="#24FFFFFF"
                                BorderThickness="1"
                                CornerRadius="22"
                                IsHitTestVisible="False">
                            <StackPanel>
                                <TextBlock FontSize="22"
                                           FontWeight="SemiBold"
                                           Text="操作提示" />
                                <TextBlock Margin="0,16,0,0"
                                           Foreground="#D7E6FF"
                                           Text="1. 顶部“编辑屏幕”可以切换每块显示器的独立布局。"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#D7E6FF"
                                           Text="2. 右键区域可添加横向或纵向二等分、三等分。"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#D7E6FF"
                                           Text="3. 右键分割线可直接删除当前分割，拖动分割线会实时调整比例。"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#D7E6FF"
                                           Text="4. 右键菜单里的“快速切换吸附布局”会立刻更新当前屏幕后续 Shift 吸附使用的布局。"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#D7E6FF"
                                           Text="5. 拖动窗口时按住吸附触发键会按窗口所在屏幕显示对应吸附布局，高亮区域后松手即可吸附。"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#D7E6FF"
                                           Text="6. 最小化快捷键会把工具收进托盘，真正退出请使用托盘右键菜单。"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="4"
                        Padding="18,16"
                        Background="#80131A28"
                        BorderBrush="#20FFFFFF"
                        BorderThickness="1"
                        CornerRadius="18"
                        IsHitTestVisible="False">
                    <TextBlock Foreground="#A9C8FF"
                               Text="现在启动后默认进入吸附待命。右键菜单、设置窗口、布局切换都会保持在最顶层，方便你直接在桌面流里连续操作。"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
